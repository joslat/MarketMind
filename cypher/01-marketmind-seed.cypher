// ---------- CONSTRAINS (seed-only exposure) ----------
UNWIND [
  {a:'cond_us_china_chip_controls', b:'NVDA', v:0.6, sg:-1, ch:'policy', src:'BIS 2022-10-07 rule; CNBC 2023-10-17 (A800/H800 ban); company filings on China revenue at risk'},
  {a:'cond_us_china_chip_controls', b:'AMD', v:0.4, sg:-1, ch:'policy', src:'BIS rule names MI/AI accelerators; AMD flagged China datacenter-GPU sales restricted'},
  {a:'cond_us_china_chip_controls', b:'ASML', v:0.55, sg:-1, ch:'policy', src:'EUV banned to China; advanced-DUV (NXT:2000i+) restricted under US+NL controls; China was a large bookings share'},
  {a:'cond_us_china_chip_controls', b:'AMAT', v:0.5, sg:-1, ch:'policy', src:'BIS WFE controls curb deposition/etch tool exports to advanced Chinese fabs; China a major revenue region'},
  {a:'cond_us_china_chip_controls', b:'LRCX', v:0.5, sg:-1, ch:'policy', src:'Lam etch/deposition equipment exports to China curbed; large China revenue exposure'},
  {a:'cond_us_china_chip_controls', b:'KLAC', v:0.45, sg:-1, ch:'policy', src:'KLA process-control/metrology tools restricted; US-person support to Chinese fabs limited'},
  {a:'cond_us_china_chip_controls', b:'8035.T', v:0.4, sg:-1, ch:'policy', src:'Tokyo Electron WFE exports to China curbed under aligned Japan controls (Jul-2023); large China sales mix'},
  {a:'cond_us_china_chip_controls', b:'SMIC', v:0.4, sg:1, ch:'policy', src:'Reuters/Fortune: SMIC benefits as China customers forced to domestic foundries; self-sufficiency bid offsets tool-access constraint in stock reaction'},
  {a:'cond_us_china_chip_controls', b:'HUAHONG', v:0.35, sg:1, ch:'policy', src:'Hua Hong is a mature-node localization beneficiary of forced China self-sufficiency under the controls'},
  {a:'cond_us_china_tariffs', b:'AAPL', v:0.4, sg:-1, ch:'policy', src:'China-concentrated assembly + China end-market revenue; Section 301 tariff escalation is a recurring overhang'},
  {a:'cond_us_china_tariffs', b:'TSLA', v:0.3, sg:-1, ch:'policy', src:'Shanghai Gigafactory output + China demand exposed to retaliatory tariffs/trade-war risk'},
  {a:'cond_us_china_tariffs', b:'BABA', v:0.3, sg:-1, ch:'policy', src:'US-listed China exporter/internet name pressured by US-China trade escalation and tariff-driven China-risk sentiment'}
] AS e
MATCH (cond:Condition {id:e.a}),(c:Company {ticker:e.b})
MERGE (cond)-[r:CONSTRAINS]->(c) SET r.value=e.v, r.sign=e.sg, r.channel=e.ch, r.source=e.src;

// =======================================================================
// NEWS EVENTS  (AFFECTS company hits; macro seeds -> country/commodity/theme/condition)
// =======================================================================

// evt_tsmc_quake_2024  (2024-04-03, supply_chain_disruption, scope=company)
MERGE (e:NewsEvent {id:'evt_tsmc_quake_2024'})
  SET e.headline = 'Magnitude 7.4 earthquake hits Taiwan; TSMC halts production at multiple fabs',
      e.source = 'Reuters', e.url = 'https://www.reuters.com/world/asia-pacific/taiwan-earthquake-2024-04-03/',
      e.sentiment = -0.85, e.category = 'supply_chain_disruption', e.scope = 'company',
      e.date = '2024-04-03', e.ts = datetime('2024-04-03T00:00:00Z');
WITH 1 AS _
UNWIND [
  {t:'TSMC', d:0.85, sg:-1, why:'Fabs evacuated and wafers in process scrapped; output disrupted'}
] AS h
MATCH (e:NewsEvent {id:'evt_tsmc_quake_2024'}),(c:Company {ticker:h.t})
MERGE (e)-[a:AFFECTS]->(c) SET a.directImpact = h.d, a.sign = h.sg, a.why = h.why;

// evt_nvda_ai_surge_2024  (2024-02-22, demand_surge, scope=company)
MERGE (e:NewsEvent {id:'evt_nvda_ai_surge_2024'})
  SET e.headline = 'NVIDIA posts record datacenter revenue as AI demand surges; shares jump',
      e.source = 'Bloomberg', e.url = 'https://www.bloomberg.com/news/articles/nvidia-q4-fy24-earnings-2024-02-21',
      e.sentiment = 0.8, e.category = 'demand_surge', e.scope = 'company',
      e.date = '2024-02-22', e.ts = datetime('2024-02-22T00:00:00Z');
WITH 1 AS _
UNWIND [
  {t:'NVDA', d:0.8, sg:1, why:'Datacenter revenue blowout and strong guidance after Feb 21 close'}
] AS h
MATCH (e:NewsEvent {id:'evt_nvda_ai_surge_2024'}),(c:Company {ticker:h.t})
MERGE (e)-[a:AFFECTS]->(c) SET a.directImpact = h.d, a.sign = h.sg, a.why = h.why;

// evt_chip_export_curbs_2024  (2024-12-02, regulatory, scope=company)
MERGE (e:NewsEvent {id:'evt_chip_export_curbs_2024'})
  SET e.headline = 'US tightens export controls on advanced chips and equipment to China',
      e.source = 'WSJ', e.url = 'https://www.wsj.com/tech/us-china-chip-export-controls-december-2024',
      e.sentiment = -0.49, e.category = 'regulatory', e.scope = 'company',
      e.date = '2024-12-02', e.ts = datetime('2024-12-02T00:00:00Z');
WITH 1 AS _
UNWIND [
  {t:'NVDA', d:0.55, sg:-1, why:'Tighter limits on advanced AI accelerator sales to China'},
  {t:'ASML', d:0.5, sg:-1, why:'Lithography tool shipments to Chinese fabs further restricted'},
  {t:'AMAT', d:0.45, sg:-1, why:'Deposition/etch equipment exports curbed'},
  {t:'LRCX', d:0.45, sg:-1, why:'Etch equipment exports to China curbed'}
] AS h
MATCH (e:NewsEvent {id:'evt_chip_export_curbs_2024'}),(c:Company {ticker:h.t})
MERGE (e)-[a:AFFECTS]->(c) SET a.directImpact = h.d, a.sign = h.sg, a.why = h.why;

// evt_tesla_q1_miss_2024  (2024-04-02, earnings, scope=company)
MERGE (e:NewsEvent {id:'evt_tesla_q1_miss_2024'})
  SET e.headline = 'Tesla Q1 deliveries fall well short of estimates',
      e.source = 'CNBC', e.url = 'https://www.cnbc.com/2024/04/02/tesla-tsla-q1-2024-vehicle-delivery-and-production-numbers.html',
      e.sentiment = -0.6, e.category = 'earnings', e.scope = 'company',
      e.date = '2024-04-02', e.ts = datetime('2024-04-02T00:00:00Z');
WITH 1 AS _
UNWIND [
  {t:'TSLA', d:0.6, sg:-1, why:'First YoY delivery decline in years; demand and price-cut worries'}
] AS h
MATCH (e:NewsEvent {id:'evt_tesla_q1_miss_2024'}),(c:Company {ticker:h.t})
MERGE (e)-[a:AFFECTS]->(c) SET a.directImpact = h.d, a.sign = h.sg, a.why = h.why;

// evt_byd_overtakes_tesla_2024  (2024-01-02, sector, scope=company)
MERGE (e:NewsEvent {id:'evt_byd_overtakes_tesla_2024'})
  SET e.headline = 'BYD overtakes Tesla as the world\'s top EV seller in Q4',
      e.source = 'Financial Times', e.url = 'https://www.ft.com/content/byd-tesla-ev-sales-q4-2023',
