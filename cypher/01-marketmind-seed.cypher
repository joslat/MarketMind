  SET e.headline = 'ASML shares plunge after orders miss and outlook cut (early release)',
      e.source = 'Reuters', e.url = 'https://www.reuters.com/technology/asml-q3-2024-results-2024-10-15/',
      e.sentiment = -0.75, e.category = 'earnings', e.scope = 'company',
      e.date = '2024-10-15', e.ts = datetime('2024-10-15T00:00:00Z');
WITH 1 AS _
UNWIND [
  {t:'ASML', d:0.75, sg:-1, why:'Bookings far below consensus; 2025 sales guidance cut'}
] AS h
MATCH (e:NewsEvent {id:'evt_asml_guidance_cut_2024'}),(c:Company {ticker:h.t})
MERGE (e)-[a:AFFECTS]->(c) SET a.directImpact = h.d, a.sign = h.sg, a.why = h.why;

// evt_intel_q2_miss_2024  (2024-08-02, earnings, scope=company)
MERGE (e:NewsEvent {id:'evt_intel_q2_miss_2024'})
  SET e.headline = 'Intel plunges on weak guidance, dividend suspension and layoffs',
