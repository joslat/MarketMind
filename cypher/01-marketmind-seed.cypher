  {a:'ETN', b:'AI-power-demand', v:0.65, sg:1, ch:'Electrical power-management gear for datacenters; AI datacenter electrification is the key growth/multiple driver, diluted by a broad industrial base.', src:'public'},
  {a:'VRT', b:'AI-power-demand', v:0.8, sg:1, ch:'Datacenter thermal/power (cooling, busbar, UPS); a near-pure AI-datacenter capex+power-density play, high transmission.', src:'public'},
