      e.sentiment = 0.04, e.category = 'election_policy', e.scope = 'policy',
      e.cv_operations = 0.05, e.cv_demand = 0.1, e.cv_currency = 0.35, e.cv_policy = 0.5,
      e.date = '2024-11-06', e.ts = datetime('2024-11-06T00:00:00Z');
WITH 1 AS _
UNWIND [
  {t:'TSLA', d:0.6, sg:1, why:'Musk-Trump alignment + EV/regulatory tailwind hopes; Tesla surged ~15% the day after the election'},
  {t:'BABA', d:0.4, sg:-1, why:'US-listed China name fell on renewed tariff / trade-war threat under the new administration'},
  {t:'JPM', d:0.35, sg:1, why:'Banks rallied on deregulation and steeper-curve / stronger-dollar reflation trade'}
] AS h
MATCH (e:NewsEvent {id:'evt_us_election_trump_2024'}),(c:Company {ticker:h.t})
MERGE (e)-[a:AFFECTS]->(c) SET a.directImpact = h.d, a.sign = h.sg, a.why = h.why;
WITH 1 AS _
MATCH (e:NewsEvent {id:'evt_us_election_trump_2024'}),(n:Condition {id:'cond_us_china_tariffs'})
MERGE (e)-[r:TIGHTENS]->(n) SET r.severity = 0.4, r.sign = -1, r.why = 'Election outcome re-prices an expanded China-tariff / trade-war stance; seeds tariff CONSTRAINS targets (China exporters and China-supply-chain names) negative';

// =======================================================================
// ImpactRecord skeletons — ground-truth slots (filled by build_golden_dataset.py -> cypher/03).
// =======================================================================
UNWIND ['evt_tsmc_quake_2024', 'evt_nvda_ai_surge_2024', 'evt_chip_export_curbs_2024', 'evt_tesla_q1_miss_2024', 'evt_byd_overtakes_tesla_2024', 'evt_asml_guidance_cut_2024', 'evt_intel_q2_miss_2024', 'evt_micron_beat_2024', 'evt_google_antitrust_2024', 'evt_samsung_strike_2024', 'evt_apple_intelligence_wwdc_2024', 'evt_nvda_blackwell_delay_2024', 'evt_tsmc_earnings_beat_2024', 'evt_visa_doj_antitrust_2024', 'evt_fed_hawkish_dec_2024', 'evt_china_stimulus_2024', 'evt_yen_carry_unwind_2024', 'evt_deepseek_selloff_2025', 'evt_broadcom_ai_beat_2024', 'evt_smci_auditor_resign_2024', 'evt_skhynix_record_q3_2024', 'evt_marvell_ai_beat_2024', 'evt_apple_iphone16_demand_2024', 'evt_nvda_gtc_blackwell_2024', 'evt_taiwan_strait_scare_2022', 'evt_chip_controls_tighten_2023', 'evt_us_election_trump_2024'] AS eid
UNWIND ['MSFT', 'NVDA', 'TSMC', 'ASML', 'AMD', 'INTC', 'MU', 'AVGO', 'QCOM', 'ARM', 'TXN', 'MRVL', 'LRCX', 'AMAT', 'SMSN', 'SKH', 'ORCL', 'IBM', 'AMZN', 'GOOGL', 'META', 'NFLX', 'BABA', 'AAPL', 'DELL', 'SMCI', 'ANET', 'CSCO', 'FOXCONN', 'WDC', 'STX', 'TSLA', 'GM', 'BYD', 'CATL', 'PANA', 'V', 'MA', 'PYPL', 'JPM', 'GS', '4063.T', '3436.T', 'ENTG', 'LIN', 'AI.PA', '8035.T', 'KLAC', '6857.T', '6920.T', 'ASM.AS', 'SNPS', 'CDNS', 'SMIC', 'HUAHONG', 'TENCENT', 'BIDU', 'XIAOMI', 'JD', 'NAVER', 'KIOXIA', 'IFX.DE', 'STM', 'NXPI', 'SAP', 'SIE.DE', 'SU.PA', 'NOK', 'ERIC', 'VST', 'CEG', 'NRG', 'GEV', 'ETN', 'VRT', 'PWR', 'F', 'RIVN', 'TM', 'VOW3', 'NIO', 'LI', 'LGES', 'ALB', 'RXRX', 'SDGR', 'ILMN', 'TEM', 'SNDK', 'NANYA', 'HANMI', 'BESI', 'XOM', 'MP', 'FCX'] AS tk
MATCH (e:NewsEvent {id:eid}),(c:Company {ticker:tk})
MERGE (e)-[:HAS_RECORD]->(ir:ImpactRecord {id:'ir_'+eid+'_'+tk})
  ON CREATE SET ir.window='1d', ir.actualReturnPct=null, ir.abnormalReturnPct=null,
                ir.source='yfinance', ir.filled=false
MERGE (ir)-[:FOR_COMPANY]->(c);
