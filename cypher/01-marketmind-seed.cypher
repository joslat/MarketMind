// ---------- Commodity nodes (seed-only) ----------
UNWIND [
  {id:'NEON', name:'Neon (semiconductor-grade)', category:'industrial_gas', geo:'Ukraine ~70% of global semiconductor-grade supply (Ingas/Cryoin, Odesa & Mariupol); purified as a steelmaking byproduct, much feedstock historically from Russia/China. China is the other large producer.'},
  {id:'ELECTRICITY', name:'Wholesale electricity / power', category:'energy', geo:'Regional/grid-bound (not globally traded); US merchant power concentrated in PJM/ERCOT. Datacenter-driven demand growth is the swing factor.'},
  {id:'CRUDE', name:'Crude oil', category:'energy', geo:'Globally traded (Brent/WTI); supply concentrated in OPEC+ (~40% of output), US shale, and Russia.'},
  {id:'LITHIUM', name:'Lithium', category:'battery_metal', geo:'Mining: Australia ~50%, Chile + Argentina (lithium triangle) ~25%; refining/processing China ~65-70%.'},
  {id:'RARE_EARTH', name:'Rare earth elements (NdPr / magnet)', category:'critical_mineral', geo:'China ~70% of mining and ~85-90% of refining/separation; MP Materials (Mountain Pass) is the main ex-China mine (~15% of global content).'}
] AS m
MERGE (x:Commodity {id:m.id}) SET x.name = m.name, x.category = m.category, x.geoConcentration = m.geo;

// ---------- Theme nodes (seed-only) ----------
UNWIND [
  {id:'AI-capex', name:'AI Datacenter Capex', kind:'narrative', desc:'The hyperscaler/sovereign AI infrastructure build-out thesis. Names move on the expectation of sustained, rising spend on AI accelerators, custom silicon, networking and full racks. This is the basket that DeepSeek (2025-01-27) re-rated: a cheap-compute shock that questions the capex trajectory hits every member, even those with no direct DeepSeek linkage. Sign +1 means the stock rises when the AI-capex narrative strengthens.'},
  {id:'HBM-memory', name:'High-Bandwidth Memory (HBM) Cycle', kind:'narrative', desc:'The AI-memory super-cycle: HBM (stacked DRAM for AI accelerators) plus the back-end packaging tools (TC bonders, hybrid bonding) that gate HBM supply. A sub-narrative of AI-capex but with its own pricing/supply dynamics (HBM is sold out, ASP-rich, and capacity-constrained), so members can decouple from broad logic. Sign +1: stock rises when HBM demand/pricing tightens.'},
  {id:'AI-power-demand', name:'AI Power Demand', kind:'narrative', desc:'The \'electricity is the bottleneck for AI\' thesis: independent power producers (esp. nuclear), grid/transmission build-out, and datacenter electrical/cooling/backup gear all re-rate on expectations that AI datacenters drive a step-change in US power demand. Sign +1: stock rises as the power-demand narrative strengthens. BEAR CASE: this theme is structurally DOWNSTREAM of AI-capex — if AI capex disappoints (a DeepSeek-style efficiency shock, or a hyperscaler capex cut), the power-demand thesis deflates too, so members also carry positive AI-capex loadings and can sell off in an AI de-rating despite no fundamental change in current power load.'},
  {id:'export-control', name:'US-China Semiconductor Export Controls', kind:'style_factor', desc:'Policy-risk factor for the US/allied chip & equipment complex exposed to China-revenue restrictions vs. the Chinese domestic champions that benefit from forced import-substitution. A TIGHTENING of controls is the shock: Western accelerator and WFE (wafer-fab-equipment) makers lose addressable China demand (sign -1), while protected, state-backed Chinese foundries gain share and subsidy (sign +1). Loadings reflect China-revenue / China-orderbook transmission, not operational dependency.'},
  {id:'China-tech', name:'China Tech / ADR Basket', kind:'style_factor', desc:'The China internet + domestic-chip basket beta: US-listed ADRs and HK-listed China-tech names that move together on China macro/regulatory risk-on/risk-off (stimulus, regulatory thaw, delisting/geopolitical headlines). Sign +1: stock rises on a China-tech re-rating (e.g. the Sep-2024 PBOC stimulus rally). Captures common basket factor exposure that no company-to-company edge expresses.'},
  {id:'EV-transition', name:'EV Transition', kind:'narrative', desc:'The global shift to battery-electric vehicles and its battery/materials supply chain. Pure-play EV makers, battery cell manufacturers and lithium producers re-rate on EV demand/penetration expectations, price wars, and subsidy/policy shifts. Sign +1: stock rises as EV-transition momentum strengthens. Note the embedded tension for legacy/diversified OEMs, where an aggressive EV transition is volume-positive but margin-dilutive (lower loading).'},
  {id:'AI-drug-discovery', name:'AI Drug Discovery / TechBio', kind:'narrative', desc:'The \'AI applied to biology\' thesis: computational drug discovery, AI-driven diagnostics/genomics, and platform TechBio names. A small, distinct sub-narrative of the broader AI trade — these stocks catch sentiment from AI-capex risk-on/risk-off but are NOT levered to hyperscaler accelerator spend, so they get a modest AI-capex loading plus a primary loading here rather than fake NVDA-supply edges. Sign +1: rises on AI-in-biology enthusiasm.'}
] AS t
MERGE (x:Theme {id:t.id}) SET x.name = t.name, x.kind = t.kind, x.description = t.desc;

// ---------- Condition nodes (standing state — seed-only) ----------
UNWIND [
  {id:'cond_us_china_chip_controls', kind:'export_control', status:'active', sd:'2022-10-07', ed:null, jur:'US', dom:'semiconductors', sev:0.7, desc:'US Bureau of Industry and Security (BIS) advanced-computing & semiconductor-manufacturing export controls on China, enacted 2022-10-07. Bans export of leading-edge AI accelerators (A100/H100 class) and advanced wafer-fab equipment (EUV/advanced DUV, advanced etch/deposition/metrology) to Chinese fabs; restricts US-person support. Tightened 2023-10-17 (A800/H800/L40 loophole closure) and again Dec-2024. Hurts US/EU chip and WFE exporters that lose China revenue; helps Chinese domestic foundries (SMIC, Hua Hong) via forced localization / self-sufficiency demand.'},
  {id:'cond_us_china_tariffs', kind:'tariff', status:'active', sd:'2018-07-06', ed:null, jur:'US', dom:'trade', sev:0.4, desc:'US Section 301 tariffs on Chinese imports, first effective 2018-07-06 (List 1, 25%) and progressively broadened; still active. Hurts US firms with China-manufactured hardware or large China import/revenue exposure (Apple supply chain, autos, EV-component imports) and Chinese exporters into the US; a renewed/expanded China-tariff stance under the 2024 Trump win is the policy overhang re-priced by markets.'}
] AS d
MERGE (x:Condition {id:d.id})
  SET x.kind=d.kind, x.status=d.status, x.startDate=d.sd, x.endDate=d.ed,
      x.jurisdiction=d.jur, x.domain=d.dom, x.severity=d.sev, x.description=d.desc;

