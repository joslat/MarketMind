      e.date = '2024-01-02', e.ts = datetime('2024-01-02T00:00:00Z');
WITH 1 AS _
UNWIND [
  {t:'BYD', d:0.6, sg:1, why:'Record quarterly BEV deliveries; took the global volume crown'},
  {t:'TSLA', d:0.45, sg:-1, why:'Lost the top-seller title; intensifying EV price war'}
] AS h
MATCH (e:NewsEvent {id:'evt_byd_overtakes_tesla_2024'}),(c:Company {ticker:h.t})
MERGE (e)-[a:AFFECTS]->(c) SET a.directImpact = h.d, a.sign = h.sg, a.why = h.why;

// evt_asml_guidance_cut_2024  (2024-10-15, earnings, scope=company)
