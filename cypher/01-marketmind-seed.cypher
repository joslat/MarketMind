// ---------- PRODUCES (seed-only exposure) ----------
UNWIND [
  {a:'XOM', b:'CRUDE', v:0.85, sg:1, ch:'commodity', src:'ExxonMobil is an integrated oil major; upstream earnings track crude prices, so XOM moves strongly same-sign with crude.'},
  {a:'MP', b:'RARE_EARTH', v:0.9, sg:1, ch:'commodity', src:'MP Materials is a near-pure-play NdPr/rare-earth producer (Mountain Pass); its equity is highly levered to rare-earth (esp. NdPr) prices.'},
  {a:'FCX', b:'RARE_EARTH', v:0.1, sg:1, ch:'commodity', src:'FCX is primarily a copper/gold producer (no commodity in this lite set); only a weak, indirect critical-minerals readthrough. Low weight, flagged as soft.'},
  {a:'LIN', b:'NEON', v:0.15, sg:1, ch:'commodity', src:'Linde is a top global industrial-gas major that purifies/sells semiconductor-grade neon, but neon is a tiny fraction of revenue; transmission to LIN stock is small (mostly a pricing-power tailwind during shortages).'},
  {a:'AI.PA', b:'NEON', v:0.15, sg:1, ch:'commodity', src:'Air Liquide is the other major industrial-gas producer of rare gases incl. neon; same as Linde, neon is immaterial to group revenue, so weak same-sign transmission.'},
  {a:'CEG', b:'ELECTRICITY', v:0.7, sg:1, ch:'commodity', src:'Constellation is the largest US nuclear/merchant-power generator; earnings and stock are highly levered to wholesale power prices (and datacenter PPA demand). Same-sign.'},
  {a:'VST', b:'ELECTRICITY', v:0.7, sg:1, ch:'commodity', src:'Vistra is a merchant power generator (gas/nuclear/solar); equity is a high-beta play on power prices and AI-datacenter demand. Same-sign.'},
  {a:'NRG', b:'ELECTRICITY', v:0.55, sg:1, ch:'commodity', src:'NRG is an integrated power/retail generator; levered to power prices but more hedged/retail-buffered than pure merchants, so somewhat lower transmission.'},
  {a:'ALB', b:'LITHIUM', v:0.85, sg:1, ch:'commodity', src:'Albemarle is the largest pure-play lithium producer; equity tracks lithium (spodumene/carbonate) prices very closely. Strong same-sign.'}
] AS e
MATCH (c:Company {ticker:e.a}),(n:Commodity {id:e.b})
MERGE (c)-[r:PRODUCES]->(n) SET r.value=e.v, r.sign=e.sg, r.channel=e.ch, r.source=e.src;

// ---------- CONSUMES (seed-only exposure) ----------
UNWIND [
  {a:'TSMC', b:'NEON', v:0.35, sg:-1, ch:'operations', src:'Neon is a key DUV excimer-laser lithography gas; a neon spike/shortage is an input-cost and supply-continuity risk for the leading-edge fab. War->neon->chips chain. Opposite-sign (cost up = bad).'},
  {a:'SMSN', b:'NEON', v:0.3, sg:-1, ch:'operations', src:'Large memory+logic fab; significant DUV-litho neon consumer. Input-cost/continuity risk on a neon shock.'},
  {a:'INTC', b:'NEON', v:0.28, sg:-1, ch:'operations', src:'IDM with large DUV-litho footprint; neon-shortage exposure on the cost/continuity side.'},
  {a:'MU', b:'NEON', v:0.28, sg:-1, ch:'operations', src:'DRAM/NAND fabs run heavy DUV lithography; neon-supply shock is an operational/cost risk.'},
  {a:'SKH', b:'NEON', v:0.28, sg:-1, ch:'operations', src:'SK hynix memory fabs are major DUV-litho neon consumers; opposite-sign cost/continuity exposure.'},
  {a:'MSFT', b:'ELECTRICITY', v:0.08, sg:-1, ch:'operations', src:'Datacenter power is a real and growing cost, but immaterial to MSFT margins today; weak opposite-sign cost transmission (power->datacenter chain). Low weight, honest.'},
  {a:'META', b:'ELECTRICITY', v:0.1, sg:-1, ch:'operations', src:'Heavy AI-datacenter power consumer; power cost is a growing but still small share of opex. Weak opposite-sign transmission.'},
  {a:'AWS', b:'ELECTRICITY', v:0.1, sg:-1, ch:'operations', src:'Largest hyperscale datacenter operator; rising power cost is a margin headwind but small vs total. Non-tradable node (propagates to AMZN). Weak opposite-sign.'},
  {a:'GCP', b:'ELECTRICITY', v:0.1, sg:-1, ch:'operations', src:'Hyperscale datacenter power consumer; weak opposite-sign cost transmission. Non-tradable node (propagates to GOOGL).'},
  {a:'TSMC', b:'ELECTRICITY', v:0.12, sg:-1, ch:'operations', src:'Fabs are extremely power-intensive (TSMC is a top single consumer of Taiwan\'s electricity); power cost/availability is a real but margin-buffered headwind. Weak-to-moderate opposite-sign.'},
  {a:'F', b:'CRUDE', v:0.2, sg:-1, ch:'demand', src:'High oil/gasoline prices dampen demand for ICE/large trucks (Ford\'s profit pool) and raise input/logistics costs; opposite-sign demand transmission.'},
  {a:'GM', b:'CRUDE', v:0.2, sg:-1, ch:'demand', src:'High oil hits demand for GM\'s ICE truck/SUV mix and raises costs; opposite-sign demand transmission.'},
  {a:'TM', b:'CRUDE', v:0.12, sg:-1, ch:'demand', src:'Toyota is more hybrid-weighted, so less oil-sensitive than US truck makers, but high oil still pressures volumes/costs. Opposite-sign, smaller.'},
  {a:'TSLA', b:'CRUDE', v:0.18, sg:1, ch:'demand', src:'SUBSTITUTION angle: high crude/gasoline prices IMPROVE the relative economics of EVs, a demand tailwind for Tesla. Modeled as CONSUMES with POSITIVE sign (sign-flipped vs a normal consumer) to capture the oil->EV substitution. Explicitly noted.'},
  {a:'BYD', b:'CRUDE', v:0.15, sg:1, ch:'demand', src:'Same EV substitution angle: high oil aids EV/PHEV adoption (BYD also sells PHEVs, so slightly weaker pure-EV effect). CONSUMES with POSITIVE sign. Noted.'},
  {a:'CATL', b:'LITHIUM', v:0.25, sg:-1, ch:'operations', src:'World\'s largest battery maker; lithium is a major cell input cost. Note: CATL passes through cost and benefits from volume, so net stock effect is partly offset, hence moderate opposite-sign weight.'},
  {a:'LGES', b:'LITHIUM', v:0.25, sg:-1, ch:'operations', src:'Major battery maker; lithium input-cost exposure, partly passed through. Moderate opposite-sign.'},
  {a:'PANA', b:'LITHIUM', v:0.18, sg:-1, ch:'operations', src:'Battery maker (Tesla supplier) but lithium is a smaller share of diversified Panasonic; opposite-sign, smaller.'},
  {a:'TSLA', b:'LITHIUM', v:0.15, sg:-1, ch:'operations', src:'Lithium is a battery input cost for Tesla\'s vehicles/energy storage; high lithium = margin headwind. Opposite-sign, modest (Tesla buys cells/has supply deals).'},
  {a:'BYD', b:'LITHIUM', v:0.18, sg:-1, ch:'operations', src:'BYD is vertically integrated (makes its own batteries), so lithium price is a direct input cost. Opposite-sign.'},
  {a:'F', b:'RARE_EARTH', v:0.08, sg:-1, ch:'operations', src:'NdFeB permanent magnets are used in EV traction motors; a rare-earth squeeze (esp. China export curbs) is a cost/continuity risk. Small share of cost, weak transmission.'},
  {a:'GM', b:'RARE_EARTH', v:0.08, sg:-1, ch:'operations', src:'EV motor magnets use rare earths (NdPr); rare-earth supply shock is an input/continuity risk. Weak opposite-sign.'},
  {a:'TSLA', b:'RARE_EARTH', v:0.1, sg:-1, ch:'operations', src:'Permanent-magnet motors use rare earths; supply/price shock is a cost/continuity risk (Tesla has moved to cut rare-earth use, so modest). Opposite-sign.'},
  {a:'BYD', b:'RARE_EARTH', v:0.1, sg:-1, ch:'operations', src:'EV motor magnets; rare-earth input/continuity exposure (China-sourced, so closer to supply). Opposite-sign.'}
] AS e
MATCH (c:Company {ticker:e.a}),(n:Commodity {id:e.b})
MERGE (c)-[r:CONSUMES]->(n) SET r.value=e.v, r.sign=e.sg, r.channel=e.ch, r.source=e.src;

