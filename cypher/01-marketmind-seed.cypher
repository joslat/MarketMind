// =======================================================================
// MARKETMIND — SEED  (GENERATED by tools/gen_seed.py — DO NOT HAND-EDIT)
// Source of truth: data/companies.json + edges.json + events.json + macro.json
// Idempotent (MERGE). Safe to re-run. Run in Neo4j Browser or cypher-shell.
//
// 104 companies · 257 cascade edges · 27 events
// macro: 5 commodities · 7 themes · 2 conditions · 201 exposure edges (SEED-ONLY)
//
// Cascade walks ONLY SUPPLIES_TO|PARTNERS_WITH|OWNS|COMPETES_WITH. Country/Sector/Commodity/
// Theme/Condition + exposure edges are SEED-ONLY context — never traversed company->company.
// =======================================================================

// ---------- Constraints ----------
CREATE CONSTRAINT company_ticker IF NOT EXISTS FOR (c:Company)      REQUIRE c.ticker IS UNIQUE;
CREATE CONSTRAINT news_id        IF NOT EXISTS FOR (n:NewsEvent)    REQUIRE n.id     IS UNIQUE;
CREATE CONSTRAINT impact_id      IF NOT EXISTS FOR (i:ImpactRecord) REQUIRE i.id     IS UNIQUE;
CREATE CONSTRAINT country_code   IF NOT EXISTS FOR (k:Country)      REQUIRE k.code   IS UNIQUE;
CREATE CONSTRAINT sector_name    IF NOT EXISTS FOR (s:Sector)       REQUIRE s.name   IS UNIQUE;
CREATE CONSTRAINT commodity_id   IF NOT EXISTS FOR (m:Commodity)    REQUIRE m.id     IS UNIQUE;
CREATE CONSTRAINT theme_id       IF NOT EXISTS FOR (h:Theme)        REQUIRE h.id     IS UNIQUE;
CREATE CONSTRAINT condition_id   IF NOT EXISTS FOR (d:Condition)    REQUIRE d.id     IS UNIQUE;

